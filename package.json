{
  "name": "aispec",
  "displayName": "AISpec",
  "description": "AI Feature Development Assistant - Generate comprehensive prompts for feature development",
  "version": "0.0.14",
  "publisher": "PonsMauro",
  "repository": "https://github.com/ponsmauro/aispec",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Programming Languages",
    "Machine Learning"
  ],
  "tags": [
    "ai",
    "prompt",
    "planning",
    "feature-development",
    "claude",
    "gpt",
    "gemini",
    "copilot",
    "cursor"
  ],
  "activationEvents": [
    "onView:aiscpec.sidebarView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiscpec",
          "title": "AISpec",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "aiscpec": [
        {
          "type": "webview",
          "id": "aiscpec.sidebarView",
          "name": "Feature Planner"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && npm version patch && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.2"
  }
}
