{
  "name": "aispec",
  "displayName": "AISpec",
  "description": "AI Feature Development Assistant - Generate comprehensive prompts for feature development",
  "version": "0.0.2",
  "publisher": "PonsMauro",
  "repository": "https://github.com/ponsmauro/aispec",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:aiscpec.sidebarView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiscpec",
          "title": "AIScpec",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "aiscpec": [
        {
          "type": "webview",
          "id": "aiscpec.sidebarView",
          "name": "Feature Planner"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.2"
  }
}
